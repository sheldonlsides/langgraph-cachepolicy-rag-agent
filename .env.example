# Copy this file to `.env` and fill in your own keys.
# `load_dotenv()` is called by src/cache_aware_rag.ipynb.

# ---- Required ----

# Used for chat (gpt-4o-mini-2024-07-18, pinned in the notebook). Embeddings default to local HuggingFace BGE-large
# (no key needed); only the commented-out OpenAI embedding fallback uses this key.
# The notebook will prompt via getpass if this is missing.
OPENAI_API_KEY=

# ---- Optional but recommended ----

# Enables LangSmith tracing. Without it, the notebook prints local timing only.
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# HuggingFace token. Not used by the default lesson — the default BGE-large embedding
# model is public. Only needed if you switch to a gated HuggingFace embedding model.
HF_TOKEN=
# HUGGINGFACEHUB_API_TOKEN=

# Sent as the User-Agent header on Wikipedia / HTTP calls.
USER_AGENT="rag-notebook-agents/1.0"
